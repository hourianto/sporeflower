package pkg;

import java.util.ArrayList;
import java.util.Collection;
import java.util.List;

public class TestClassCast {
   public void test(List list) {
      List a = list;// 22
      if (a != null) {// 23
         (a = (List)(new ArrayList((Collection)a))).add("23");// 24
      }

      System.out.println(a.size());// 26
   }// 27
}

